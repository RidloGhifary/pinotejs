{
  "name": "pinotejs",
  "version": "0.1.2",
  "description": "Pinote is a lightweight JavaScript feedback layer for adding Figma-style comments to any website.",
  "keywords": [
    "pinotejs",
    "feedback-layer",
    "comment-layer",
    "annotations",
    "website-feedback",
    "figma-style-comments",
    "design-review",
    "javascript",
    "react",
    "nextjs"
  ],
  "homepage": "https://pinotejs.ridlolabs.net",
  "bugs": {
    "url": "https://github.com/RidloGhifary/pinote/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RidloGhifary/pinote.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs",
      "default": "./dist/react.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --environment jsdom"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
