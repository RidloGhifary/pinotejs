{
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "dev:react": "pnpm --filter @pinotejs/demo-react dev",
    "dev:vanilla": "pnpm --filter demo-vanilla dev",
    "build": "pnpm -r build",
    "build:package": "cd packages/pinote && pnpm build",
    "pack:package": "cd packages/pinote && pnpm build && pnpm pack",
    "pack:dry-run": "cd packages/pinote && npm pack --dry-run",
    "publish:package": "cd packages/pinote && pnpm build && npm publish",
    "prepack": "node -e \"throw new Error('Run pack from packages/pinote: cd packages/pinote && npm pack --dry-run')\"",
    "prepublishOnly": "node -e \"throw new Error('Run publish from packages/pinote: cd packages/pinote && npm publish')\"",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
